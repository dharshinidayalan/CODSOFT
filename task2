<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dharshini Portfolio</title>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family: Arial, sans-serif;
        }

        body{
            background:#f5f7fa;
            color:#333;
            line-height:1.6;
        }

        /* Header */

        header{
            background:linear-gradient(135deg,#4a90e2,#6a5acd);
            color:white;
            text-align:center;
            padding:70px 20px;
        }

        header h1{
            font-size:50px;
            margin-bottom:10px;
        }

        header p{
            font-size:22px;
            letter-spacing:1px;
        }

        /* Navigation */

        nav{
            background:#222;
            padding:15px;
            text-align:center;
            position:sticky;
            top:0;
            z-index:1000;
        }

        nav a{
            color:white;
            text-decoration:none;
            margin:0 20px;
            font-size:18px;
            transition:0.3s;
        }

        nav a:hover{
            color:#4a90e2;
        }

        /* Sections */

        section{
            width:90%;
            max-width:1100px;
            margin:60px auto;
        }

        h2{
            color:#4a90e2;
            margin-bottom:25px;
            border-left:6px solid #4a90e2;
            padding-left:12px;
            font-size:32px;
        }

        /* About */

        .about{
            display:flex;
            align-items:center;
            gap:40px;
            flex-wrap:wrap;
            background:white;
            padding:35px;
            border-radius:15px;
            box-shadow:0 4px 15px rgba(0,0,0,0.1);
        }

        .about img{
            width:230px;
            height:230px;
            border-radius:50%;
            object-fit:cover;
            border:5px solid #4a90e2;
        }

        .about p{
            flex:1;
            font-size:18px;
            text-align:justify;
        }

        /* Skills */

        .skills ul{
            display:flex;
            flex-wrap:wrap;
            gap:20px;
            list-style:none;
        }

        .skills li{
            background:#4a90e2;
            color:white;
            padding:12px 25px;
            border-radius:30px;
            font-size:18px;
            transition:0.3s;
        }

        .skills li:hover{
            background:#6a5acd;
            transform:scale(1.05);
        }

        /* Projects */

        .projects{
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
            gap:25px;
        }

        .project-card{
            background:white;
            border-radius:15px;
            overflow:hidden;
            box-shadow:0 4px 15px rgba(0,0,0,0.1);
            transition:0.3s;
        }

        .project-card:hover{
            transform:translateY(-10px);
        }

        .project-card img{
            width:100%;
            height:220px;
            object-fit:cover;
        }

        .project-card h3{
            color:#4a90e2;
            padding:15px 20px 10px;
        }

        .project-card p{
            padding:0 20px 20px;
            text-align:justify;
        }

        /* Resume */

        .resume{
            text-align:center;
            background:white;
            padding:40px;
            border-radius:15px;
            box-shadow:0 4px 15px rgba(0,0,0,0.1);
        }

        .resume a{
            display:inline-block;
            margin-top:20px;
            background:#4a90e2;
            color:white;
            padding:14px 30px;
            border-radius:8px;
            text-decoration:none;
            font-size:18px;
            transition:0.3s;
        }

        .resume a:hover{
            background:#6a5acd;
        }

        /* Contact */

        .contact{
            background:white;
            padding:35px;
            border-radius:15px;
            box-shadow:0 4px 15px rgba(0,0,0,0.1);
        }

        .contact p{
            font-size:18px;
            margin:15px 0;
        }

        /* Footer */

        footer{
            background:#222;
            color:white;
            text-align:center;
            padding:20px;
            margin-top:50px;
            font-size:16px;
        }

        /* Responsive */

        @media(max-width:768px){

            header h1{
                font-size:36px;
            }

            header p{
                font-size:18px;
            }

            nav a{
                display:block;
                margin:10px 0;
            }

            .about{
                text-align:center;
                justify-content:center;
            }

            .about p{
                text-align:center;
            }
        }

    </style>
</head>

<body>

